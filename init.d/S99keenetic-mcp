#!/bin/sh

case "$1" in
    start)
        python3 /opt/keenetic-mcp/server.py > /dev/null 2>&1 &
        echo $! > /tmp/keenetic-mcp.pid
        echo "Keenetic MCP started"
        ;;
    stop)
        kill $(cat /tmp/keenetic-mcp.pid 2>/dev/null) 2>/dev/null
        rm -f /tmp/keenetic-mcp.pid
        echo "Keenetic MCP stopped"
        ;;
    restart)
        $0 stop
        sleep 1
        $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        ;;
esac