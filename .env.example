# Keenetic router connection
KEENETIC_HOST=http://192.168.1.1
KEENETIC_USER=admin
KEENETIC_PASS=your_password_here

# MCP server
MCP_SECRET=your_secret_token_here
MCP_PORT=9584

# Config backup (optional)
# Set BACKUP_ENABLED=true to activate scheduled backups
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 11 * * 0
# BACKUP_SCHEDULE examples:
#   0 11 * * 0   — every Sunday at 11:00
#   0 3  * * *   — every day at 03:00
#   0 */6 * * *  — every 6 hours

# Remote destination via rsync over SSH (recommended)
# If set, backup is written to /tmp (RAM) and synced — flash is not used
# If not set, backup is stored locally in BACKUP_PATH
BACKUP_RSYNC_HOST=
BACKUP_RSYNC_USER=
BACKUP_RSYNC_KEY=/opt/etc/keenetic-backup-rsa
BACKUP_RSYNC_PATH=/share/backups/keenetic

# Local fallback (used only if BACKUP_RSYNC_HOST is not set)
BACKUP_PATH=/opt/var/backup/keenetic
BACKUP_KEEP=8